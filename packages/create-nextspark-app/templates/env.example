# NextSpark Environment Configuration
# Documentation: https://nextspark.dev/docs/configuration

# =============================================================================
# APP CONFIGURATION
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=My NextSpark App

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL connection string used for USER requests. RLS is only evaluated
# when this connects as a NON-OWNER role (e.g. `nextspark_app`, migration 022).
DATABASE_URL="postgresql://user:password@localhost:5432/nextspark?schema=public"

# SERVICE connection for SYSTEM operations that BYPASS RLS (Better Auth login,
# scheduler/processor, payment webhooks, superadmin bypass, team/subscription
# bootstrap). Supabase: the `service_role` string. Optional — falls back to
# DATABASE_URL when unset (pre-cutover).
# DATABASE_SERVICE_URL="postgresql://service_role:password@localhost:5432/nextspark?schema=public"

# Connection used to RUN MIGRATIONS/seeds (must be the table OWNER). Optional —
# falls back to DATABASE_URL when unset.
# MIGRATE_DATABASE_URL="postgresql://owner:password@localhost:5432/nextspark?schema=public"

# =============================================================================
# AUTHENTICATION (Better Auth)
# =============================================================================
# Generate a secure secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your-super-secret-key-change-this
BETTER_AUTH_URL=http://localhost:3000

# =============================================================================
# EMAIL (Resend)
# =============================================================================
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com

# =============================================================================
# PAYMENTS (Stripe)
# =============================================================================
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# =============================================================================
# OAUTH PROVIDERS (Optional)
# =============================================================================
# Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub OAuth
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
